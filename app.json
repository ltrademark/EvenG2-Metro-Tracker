{
  "package_id": "com.ltrademark.wmatatracker",
  "edition": "202601",
  "name": "MetroTracker",
  "version": "0.6.1",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Real-time DC Metro arrivals and live train positions from the official WMATA API, plus dark map tiles from CartoDB.",
      "whitelist": [
        "https://api.wmata.com",
        "https://a.basemaps.cartocdn.com",
        "https://www.ltrademark.com",
        "https://github.com"
      ]
    },
    { "name": "location", "desc": "GPS for nearest Metro station" }
  ],
  "supported_languages": ["en"]
}
